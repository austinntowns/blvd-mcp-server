# Boulevard API Credentials
# Get these from the Boulevard Developer Portal
BLVD_API_KEY=your_api_key_here
BLVD_API_SECRET=your_api_secret_here
BLVD_BUSINESS_ID=your_business_id_here

# Optional: Override the Boulevard API endpoint (defaults to production)
# BLVD_API_URL=https://dashboard.boulevard.io/api/2020-01/admin

# BTB Auto-Cleanup Configuration
# These control when BTB (buffer) blocks are automatically removed
BTB_UTILIZATION_THRESHOLD=50    # Min utilization % to consider removing blocks
BTB_MIN_GAP_MINUTES=60          # Gap threshold - remove if gap to appointment < this
BTB_LOOK_AHEAD_DAYS=14          # How many days ahead to analyze

# Pronto (team messaging)
PRONTO_API_TOKEN=your_pronto_token_here
PRONTO_UTAH_CHAT_ID=your_chat_id_here

# Google Cloud (for BigQuery when running outside GCP)
# Paste the full service account JSON here — the script writes it to a temp file at boot
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# GitHub (for pushing daily briefs to Obsidian vault repo)
# When both are set, the script pushes via GitHub API instead of local filesystem
GITHUB_TOKEN=your_github_pat_here
OBSIDIAN_REPO=austinntowns/obsidian-vaults
